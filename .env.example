# Copy this file to `.env` (or `.env.local`) and fill in real values.
# NEVER commit the real .env — it is gitignored.

# ---- MySQL database ----
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=hellomayor
ADMIN_SECRET=ADMINSUPERSECRETKEY
# Max pooled connections (optional, defaults to 10)
DB_CONNECTION_LIMIT=10

# ---- Admin auth ----
# Secret used to sign admin session tokens (HMAC). Use a long random string.
# Generate one with: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-long-random-secret

# ---- Media upload (VPS) ----
# Used by the gallery upload route to push files to your VPS.
VPS_API_URL=https://your-vps-host.example.com
VPS_API_KEY=your-vps-api-key
